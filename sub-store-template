{
  "log": {
    "level": "info",
    "timestamp": true
  },
  "experimental": {
    "cache_file": {
      "enabled": true,
      "path": "cache.db",
      "cache_id": "",
      "store_fakeip": true,
      "store_dns": true
    },
    "clash_api": {
      "external_controller": "127.0.0.1:9090",
      "external_ui": "ui",
      "external_ui_download_detour": "Proxy",
      "external_ui_download_url": "https://github.com/MetaCubeX/metacubexd/archive/refs/heads/gh-pages.zip"
    }
  },
  "dns": {
    "servers": [
      {
        "tag": "proxy_dns",
        "type": "https",
        "server": "8.8.8.8"
      },
      {
        "tag": "local_dns",
        "type": "https",
        "server": "223.5.5.5"
      }
    ],
    "rules": [
      {
        "clash_mode": "Direct",
        "action": "route",
        "server": "local_dns"
      },
      {
        "clash_mode": "Global",
        "action": "route",
        "server": "proxy_dns"
      },
      {
        "rule_set": ["geosite-geolocation-!cn"],
        "action": "route",
        "server": "proxy_dns"
      }
    ],
    "disable_cache": false,
    "disable_expire": false,
    "independent_cache": false,
    "final": "local_dns"
  },
  "inbounds": [
    {
      "type": "tun",
      "tag": "tun-in",
      "address": ["172.18.0.1/30", "fdfe:dcba:9876::1/126"],
      "mtu": 1400,
      "auto_route": true,
      "strict_route": true,
      "route_exclude_address_set": ["geoip-cn"],
      "stack": "mixed",
      "platform": {
        "http_proxy": {
          "enabled": true,
          "server": "127.0.0.1",
          "server_port": 20122
        }
      }
    },
    {
      "type": "mixed",
      "tag": "mixed-in",
      "listen": "127.0.0.1",
      "listen_port": 20122,
      "tcp_fast_open": true,
      "tcp_multi_path": true,
      "udp_fragment": false
    }
  ],
  "outbounds": [
    {
      "tag": "Direct",
      "type": "direct"
    },
    {
      "tag": "Proxy",
      "type": "selector",
      "default": "Singapore",
      "outbounds": [
        "Auto",
        "Singapore",
        "United States",
        "Taiwan",
        "Hong Kong",
        "Japan",
        "Europe",
        "Others",
        "Direct"
      ]
    },
    {
      "tag": "Singapore",
      "type": "selector",
      "outbounds": []
    },
    {
      "tag": "United States",
      "type": "selector",
      "outbounds": []
    },
    {
      "tag": "Taiwan",
      "type": "selector",
      "outbounds": []
    },
    {
      "tag": "Hong Kong",
      "type": "selector",
      "outbounds": []
    },
    {
      "tag": "Japan",
      "type": "selector",
      "outbounds": []
    },
    {
      "tag": "Europe",
      "type": "selector",
      "outbounds": []
    },
    {
      "tag": "Others",
      "type": "selector",
      "outbounds": []
    },
    {
      "tag": "Auto",
      "type": "urltest",
      "url": "http://1.1.1.1/generate_204",
      "interval": "5m",
      "tolerance": 5,
      "outbounds": []
    }
  ],
  "route": {
    "auto_detect_interface": true,
    "default_domain_resolver": "local_dns",
    "final": "Direct",
    "rules": [
      {
        "action": "sniff",
        "inbound": ["tun-in"]
      },
      {
        "protocol": "dns",
        "action": "hijack-dns"
      },
      {
        "ip_is_private": true,
        "action": "route",
        "outbound": "Direct"
      },
      {
        "clash_mode": "Direct",
        "action": "route",
        "outbound": "Direct"
      },
      {
        "clash_mode": "Global",
        "action": "route",
        "outbound": "Proxy"
      },
      {
        "rule_set": ["geosite-geolocation-!cn"],
        "action": "route",
        "outbound": "Proxy"
      }
    ],
    "rule_set": [
      {
        "tag": "geosite-geolocation-!cn",
        "type": "remote",
        "format": "binary",
        "url": "https://raw.githubusercontent.com/SagerNet/sing-geosite/raw/refs/heads/rule-set/geosite-geolocation-!cn.srs",
        "download_detour": "Proxy"
      },
      {
        "tag": "geoip-cn",
        "type": "remote",
        "format": "binary",
        "url": "https://raw.githubusercontent.com/SagerNet/sing-geoip/refs/heads/rule-set/geoip-cn.srs",
        "download_detour": "Proxy"
      },
      {
        "tag": "geosite-cn",
        "type": "remote",
        "format": "binary",
        "url": "https://raw.githubusercontent.com/SagerNet/sing-geosite/refs/heads/rule-set/geosite-cn.srs",
        "download_detour": "Proxy"
      }
    ]
  }
}
